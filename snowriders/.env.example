# ==========================================
# ERÜ SNOWRIDERS - ENVIRONMENT CONFIGURATION
# ==========================================

# -----------------------------------------------------
# 1. BACKEND AYARLARI (c:\Eru kayak\snowriders\backend\.env)
# -----------------------------------------------------
# (Render.com veya farklı bir sunucuya yüklerken "Environment Variables" sekmesine bunları gireceksiniz)

PORT=5000
MONGODB_URI=mongodb+srv://<kullanici_adiniz>:<sifreniz>@cluster0.mongodb.net/eru-snowriders?retryWrites=true&w=majority
JWT_SECRET=SizinCokGizliSecretSifreniz123
JWT_EXPIRES_IN=7d

# Nodemailer için Gmail Bilgileri
# Güvenlik açısından EMAIL_PASS olarak hesabınızın şifresini değil,
# Google Hesabı -> Güvenlik -> "Uygulama Şifreleri" (App Passwords) ile oluşturduğunuz 16 haneli şifreyi girin.
EMAIL_USER=sizin_mail_adresiniz@gmail.com
EMAIL_PASS=abcdefghijklmnop


# -----------------------------------------------------
# 2. FRONTEND AYARLARI (c:\Eru kayak\snowriders\frontend\.env)
# -----------------------------------------------------
# Frontend'in, API isteklerini atacağı adresi belirler.
# Projeyi Firebase veya başka bir platforma deploy ederken bu ayar mutlaka CANLI (Production) link olmalıdır.

# LOKAL TEST (Bilgisayarınızda test ederken bunu kullanın)
# VITE_API_URL=http://localhost:5000/api

# CANLI YAYIN (Render.com vb. üzerinden backend'i yayınladıktan sonra bu linki kullanın. Örn:)
VITE_API_URL=https://eru-snowriders-backend.onrender.com/api
